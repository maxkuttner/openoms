# openoms configuration. Copy to `.env`, edit, then run `make db-setup`.
# =====================================================================

# --- Postgres host ---
DB_HOST=localhost
DB_PORT=5432

# --- Install-time admin (a Postgres superuser) — used by `make db-provision`/
#     db-migrate/db-access/db-seed to create roles+db and apply schema. Not runtime. ---
ADMIN_USER=postgres
ADMIN_PASSWORD=postgres

# --- Application roles created by db-provision (choose passwords) ---
MDM_MASTER_PASSWORD=change_me_master
MARKET_USER_PASSWORD=change_me_market
OMS_USER_PASSWORD=change_me_oms

# --- Runtime: what the OMS binary connects as (least-privilege oms_user, db `ods`).
#     OMS tables live in schema `oms`, master data in `public`; oms_user's
#     search_path resolves both. ---
DB_NAME=ods
DB_USER=oms_user
DB_PASSWORD=change_me_oms
DATABASE_URL=postgres://oms_user:change_me_oms@localhost:5432/ods?sslmode=disable

# --- OMS service ---
OMS_BIND_ADDR=localhost:3001
OMS_ADMIN_TOKEN=change-me-to-a-secure-random-token
OMS_ADMIN_AUTH_ENABLED=false

# --- Kafka ---
KAFKA_BROKER=localhost:9092
KAFKA_TOPIC=orders
KAFKA_CLIENT_ID=rust-oms
KAFKA_PROJECTOR_GROUP_ID=position-projector-v1

# --- Optional: live universe seeding (`make seed-instruments` / `make sync-brokers`).
#     On-demand, NOT scheduled. The seeders write as market_user. ---
# DATABENTO_API_KEY=
ALPACA_ENV=PAPER
ALPACA_PAPER_API_KEY=
ALPACA_PAPER_API_SECRET=
